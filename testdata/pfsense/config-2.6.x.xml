<?xml version="1.0"?>
<pfsense>
  <version>21.02</version>
  <system>
    <optimization>normal</optimization>
    <hostname>fw-test</hostname>
    <domain>test.local</domain>
    <dnsallowoverride>1</dnsallowoverride>
    <dnsserver>8.8.8.8</dnsserver>
    <dnsserver>1.1.1.1</dnsserver>
    <language>en_US</language>
    <timezone>Etc/UTC</timezone>
    <timeservers>0.pfsense.pool.ntp.org 1.pfsense.pool.ntp.org</timeservers>
    <powerd_ac_mode>hadp</powerd_ac_mode>
    <bogons>
      <interval>monthly</interval>
    </bogons>
    <webgui>
      <protocol>https</protocol>
      <ssl-certref>cert-abc123</ssl-certref>
      <loginautocomplete/>
    </webgui>
    <ssh>
      <enabled/>
      <group>admins</group>
    </ssh>
    <group>
      <name>admins</name>
      <description>System Administrators</description>
      <scope>system</scope>
      <gid>1999</gid>
      <member>0</member>
      <priv>page-all</priv>
    </group>
    <user>
      <name>admin</name>
      <descr>System Administrator</descr>
      <scope>system</scope>
      <groupname>admins</groupname>
      <bcrypt-hash>$2b$10$abcdefghijklmnopqrstuuABCDEFGHIJKLMNOPQRSTUVWXYZ12</bcrypt-hash>
      <uid>0</uid>
      <priv>user-shell-access</priv>
    </user>
    <nextuid>2000</nextuid>
    <nextgid>2000</nextgid>
  </system>
  <interfaces>
    <wan>
      <if>igb0</if>
      <descr>WAN</descr>
      <enable>1</enable>
      <ipaddr>dhcp</ipaddr>
      <blockpriv>1</blockpriv>
      <blockbogons>1</blockbogons>
    </wan>
    <lan>
      <if>igb1</if>
      <descr>LAN</descr>
      <enable>1</enable>
      <ipaddr>192.168.1.1</ipaddr>
      <subnet>24</subnet>
    </lan>
  </interfaces>
  <dhcpd>
    <lan>
      <enable>1</enable>
      <range>
        <from>192.168.1.100</from>
        <to>192.168.1.200</to>
      </range>
      <staticmap>
        <mac>00:11:22:33:44:55</mac>
        <ipaddr>192.168.1.10</ipaddr>
        <hostname>printer</hostname>
        <descr>Office Printer</descr>
      </staticmap>
    </lan>
  </dhcpd>
  <filter>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <network>lan</network>
        <port>443</port>
      </destination>
      <descr>Allow HTTPS from LAN</descr>
      <tracker>1000000001</tracker>
    </rule>
    <rule>
      <type>block</type>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <source><any/></source>
      <destination><any/></destination>
      <descr>Block all inbound on WAN</descr>
      <log/>
      <tracker>1000000002</tracker>
    </rule>
  </filter>
  <nat>
    <outbound>
      <mode>automatic</mode>
    </outbound>
    <rule>
      <interface>wan</interface>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination><any/></destination>
      <target>192.168.1.50</target>
      <local-port>8080</local-port>
      <descr>Web server port forward</descr>
    </rule>
  </nat>
  <openvpn>
    <openvpn-server>
      <vpnid>1</vpnid>
      <description>Site VPN</description>
      <mode>server_tls</mode>
      <protocol>UDP4</protocol>
      <dev_mode>tun</dev_mode>
      <interface>wan</interface>
      <local_port>1194</local_port>
    </openvpn-server>
  </openvpn>
  <revision>
    <username>admin@192.168.1.100</username>
    <time>1700000000</time>
    <description>Test configuration</description>
  </revision>
  <ca>
    <refid>ca-001</refid>
    <descr>Internal CA</descr>
    <crt>LS0tLS1CRUdJTi...</crt>
  </ca>
  <cert>
    <refid>cert-abc123</refid>
    <descr>WebGUI Certificate</descr>
    <crt>LS0tLS1CRUdJTi...</crt>
    <prv>LS0tLS1CRUdJTi...</prv>
  </cert>
</pfsense>
